# ─── Web3Auth ────────────────────────────────────────────────
# Get a free Client ID at https://dashboard.web3auth.io
# Create a "Plug and Play" project, choose Sapphire Devnet network for dev.
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=

# ─── Chain ────────────────────────────────────────────────────
# Which network the app connects to: "sepolia" or "localhost"
NEXT_PUBLIC_CHAIN=sepolia

# Override the RPC URL if you have your own (Alchemy/Infura).
# Default uses the public Blast endpoint defined in @prediqt/shared.
NEXT_PUBLIC_SEPOLIA_RPC_URL=

# ─── Zama relayer (FHE encrypt/decrypt) ───────────────────────
# Default: https://relayer.testnet.zama.cloud
NEXT_PUBLIC_FHEVM_RELAYER=https://relayer.testnet.zama.cloud
