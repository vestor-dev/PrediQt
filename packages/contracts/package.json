{
  "name": "@prediqt/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Prediqt smart contracts (Zama FHEVM)",
  "scripts": {
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "node:local": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy-week1.ts --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy-week1.ts --network sepolia",
    "deploy:week3:sepolia": "hardhat run scripts/deploy-week3.ts --network sepolia",
    "deploy:week4:sepolia": "hardhat run scripts/deploy-week4.ts --network sepolia",
    "setup:agents:sepolia": "hardhat run scripts/setup-agents.ts --network sepolia",
    "resolve:sepolia": "hardhat run scripts/resolve.ts --network sepolia",
    "deploy:full:sepolia": "hardhat run scripts/deploy-full.ts --network sepolia",
    "verify:sepolia": "hardhat verify --network sepolia",
    "lint": "solhint 'contracts/**/*.sol'"
  },
  "devDependencies": {
    "@fhevm/hardhat-plugin": "^0.1.0-3",
    "@fhevm/solidity": "^0.8.0",
    "@zama-fhe/oracle-solidity": "^0.1.0",
    "encrypted-types": "^0.0.4",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.0",
    "@zama-fhe/relayer-sdk": "^0.2.0",
    "chai": "^4.5.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.4",
    "hardhat": "^2.22.17",
    "hardhat-deploy": "^0.14.0",
    "hardhat-gas-reporter": "^2.2.2",
    "mocha": "^10.8.2",
    "solhint": "^5.0.4",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.6.3"
  }
}
