# Deployer private key — used for deploying contracts to Sepolia.
# Generate a fresh wallet for this; do not reuse a personal wallet.
PRIVATE_KEY=

# Sepolia RPC. Free options: https://eth-sepolia.public.blastapi.io
# For production, use Alchemy/Infura with your own key.
SEPOLIA_RPC_URL=https://eth-sepolia.public.blastapi.io

# Optional: Etherscan API key for contract verification
ETHERSCAN_API_KEY=

# Optional: enable gas reporting on `pnpm test:gas`
REPORT_GAS=false
